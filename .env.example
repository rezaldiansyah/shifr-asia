
# ===========================================
# Shifr Asia - Root Environment Variables
# ===========================================

# App General
APP_NAME="Shifr Asia"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com

# Database (Postgres)
# If using Docker Compose / Easypanel Service Discovery
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=shifr_asia
DB_USERNAME=shifr
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend URLs for CORS
CORS_ALLOWED_ORIGINS=https://shifr.asia,https://bizup.shifr.asia

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@shifr.asia"

# Storage
CLOUDFLARE_R2_BUCKET=shifr-assets
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
