APP_NAME="Shifr Asia API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=shifr_asia
# DB_USERNAME=postgres
# DB_PASSWORD=

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Services
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# CORS - Frontend URLs
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001

# Frontend URLs
FRONTEND_SHIFR_URL=http://localhost:3000
FRONTEND_BIZUP_URL=http://localhost:3001

# Mail (using Resend for free tier)
MAIL_MAILER=log
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@shifr.asia"
MAIL_FROM_NAME="${APP_NAME}"

# Resend API (for direct API calls)
RESEND_API_KEY=
RESEND_DOMAIN_VERIFIED=false

# Payment Gateway (Mayar)
MAYAR_API_KEY=
MAYAR_WEBHOOK_SECRET=
MAYAR_SANDBOX=true

# Frontend URL for callbacks
FRONTEND_URL=http://localhost:3000

# WhatsApp (Dripsender/Sohibot)
WA_PROVIDER=dripsender
DRIPSENDER_API_KEY=
SOHIBOT_API_KEY=
